   "source": [
    "import pandas as pd\n",
    "import sqlite3\n",
    "\n",
    "\n",
    "# Run this to make the 903 database file\n",
    "db = sqlite3.connect(\"903_database.db\")\n",
    "dfs = pd.read_excel(\"/workspaces/ERN-sessions/data/903_xlsx.xlsx\", sheet_name=None)\n",
    "for table, df in dfs.items():\n",
    "    df.to_sql(table, db)\n",
    "db.commit()\n",
    "db.close()"
   ]
  }
